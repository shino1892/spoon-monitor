# .env.example
# このファイルには秘密情報を入れない（.env にコピーして各自設定）

# =============================
# Spoon
# =============================

# 監視対象DJのSpoonユーザーID
DJ_ID=

# DJ アカウント（collector用：配信 join / イベント収集）
DJ_ACCESS_TOKEN=
DJ_REFRESH_TOKEN=

# MONITOR アカウント（/check の配信検知用）
MONITOR_ACCESS_TOKEN=
MONITOR_REFRESH_TOKEN=

# =============================
# Discord
# =============================

# Discord Bot Token
DISCORD_BOT_TOKEN=

# 通知用チャンネルID（collector/monitorがDiscordへ投稿する場合のみ）
DISCORD_CHANNEL_ID=

# 通知先: channel（既定） or dm
DISCORD_NOTIFY_MODE=channel

# dm 送信に使う管理者ID（任意: DISCORD_NOTIFY_MODE=dm の場合）
DISCORD_ADMIN_ID=

# Discord 管理者（Slash Command実行者）ユーザーID
ADMIN_ID=

# Bot の Application ID（推奨。未設定でも動く場合あり）
DISCORD_APP_ID=

# 任意: 特定Guildへスラッシュコマンドを登録する場合（反映が速い）
DISCORD_GUILD_ID=

# =============================
# Optional tuning / debug
# =============================

# monitor.ts（レガシー常時監視）用の間隔
# CHECK_INTERVAL=30000

# collector.ts の listener ポーリング間隔
# LISTENER_POLL_INTERVAL=10000

# @sopia-bot/core の HTTP デバッグ（Authorization が出る可能性があるため通常は無効推奨）
# SOPIA_HTTP_DEBUG=0

# Spoon WebSocket イベントのデバッグ（collector.ts）
# SPOON_DEBUG_EVENTS=0
# SPOON_DEBUG_PAYLOAD=0
# SPOON_DEBUG_UNKNOWN_EVENTS=0
# SPOON_DEBUG_MAX_CHARS=12000