# .env example (spoon-monitor)

# --- Spoon ---
DJ_ID=312282671

# DJ アカウント（収集用）
DJ_ACCESS_TOKEN=
DJ_REFRESH_TOKEN=

# MONITOR アカウント（配信検知用）
MONITOR_ACCESS_TOKEN=
MONITOR_REFRESH_TOKEN=

# --- Discord (通知) ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=1475442686583377931

# 通知先: channel（既定） or dm
DISCORD_NOTIFY_MODE=channel
# dm の場合に送信する管理者ID（任意）
DISCORD_ADMIN_ID=345176600842731521

# --- spoon-manager（Discord Slash Commands）---
# コマンド実行を許可する管理者ID
ADMIN_ID=345176600842731521 
DISCORD_APP_ID=
# 任意: 特定Guildへ登録する場合
DISCORD_GUILD_ID=1475442645231861876

# --- 間隔 ---
# 配信チェック間隔（monitor.ts）
CHECK_INTERVAL=30000
# リスナーのポーリング間隔（collector.ts）
LISTENER_POLL_INTERVAL=10000

# --- デバッグ ---
# @sopia-bot/core の HTTP デバッグ（Authorization が出る可能性があるため通常は無効推奨）
SOPIA_HTTP_DEBUG=0

# Live オブジェクトのメソッド一覧を出力（collector.ts）
DEBUG_LIVE_METHODS=0

# Spoon WebSocket イベントのデバッグ（collector.ts）
SPOON_DEBUG_EVENTS=1
SPOON_DEBUG_PAYLOAD=1
SPOON_DEBUG_UNKNOWN_EVENTS=1
SPOON_DEBUG_MAX_CHARS=12000